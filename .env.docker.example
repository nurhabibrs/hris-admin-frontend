# Copy this file to .env and adjust values before running docker compose
# cp .env.docker.example .env

NODE_ENV=production

# Port exposed on the host machine
VITE_PORT=4000

# Base URL of the backend API (accessible from the browser, not the container)
VITE_API_URL=http://localhost:8000

# Application display name
VITE_APP_NAME=HRIS Admin Company Manager
